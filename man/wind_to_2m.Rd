\name{wind_to_2m}
\alias{wind_to_2m}
\title{Adjust wind speed to a 2 m reference height}
\usage{wind_to_2m(u, z)}
\arguments{
\item{u}{Wind speed measured at height z (m s-1).}
\item{z}{Measurement height (m).}
}
\value{Wind speed at 2 m (m s-1).}
\description{Logarithmic profile correction (FAO).}
