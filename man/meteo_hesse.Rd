summer, used in the examples. Not real measurements.}
\usage{data(meteo_hesse)}
\format{A data frame with 365 rows and 4 columns: \code{date}, \code{doy},
\code{pet} (mm/day), \code{rain} (mm/day).}
\keyword{datasets}
